+      async function fetchAllPaletteColors() {
+        // index.js style palette loader with localStorage cache and recursive fetch
+        const lsKey = "wledPalx";
+        let lsPalData = localStorage.getItem(lsKey);
+        if (lsPalData) {
+          try {
+            let d = JSON.parse(lsPalData);
+            if (d && d.p) {
+              window._allPaletteColors = d.p;
+              window._allPaletteColorsLastError = null;
+              return;
+            }
+          } catch (e) {}
+        }
+        let allColors = {};
+        let retry = false;
+        function getPalettesData(page, maxPage, done) {
+          let url = `/json/palx?page=${page}`;
+          wledApiFetch(url, { method: "get" })
+            .then((res) => {
+              if (!res.ok)
+                throw new Error("Failed to fetch palette page " + page);
+              return res.json();
+            })
+            .then((json) => {
+              retry = false;
+              if (json && json.p)
+                allColors = Object.assign({}, allColors, json.p);
+              if (page === 0 && typeof json.m === "number") maxPage = json.m;
+              if (maxPage !== undefined && page < maxPage) {
+                setTimeout(() => {
+                  getPalettesData(page + 1, maxPage, done);
+                }, 75);
+              } else {
+                window._allPaletteColors = allColors;
+                window._allPaletteColorsLastError = null;
+                localStorage.setItem(lsKey, JSON.stringify({ p: allColors }));
+                if (done) done();
+              }
+            })
+            .catch((e) => {
+              if (!retry) {
+                retry = true;
+                setTimeout(() => {
+                  getPalettesData(page, maxPage, done);
+                }, 500);
+              }
+              window._allPaletteColorsLastError = e;
+            });
+        }
