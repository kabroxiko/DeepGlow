+    <script>
+      // --- WLED Remote IP Prompt Logic ---
+      let lastPresetId = null;
+      let WLED_REMOTE_IP = localStorage.getItem("wled_remote_ip") || "";
+      function askForWledIp() {
+        let ip = prompt(
+          "Enter WLED device IP address (e.g. 192.168.1.123):",
+          WLED_REMOTE_IP || "",
+        );
+        if (ip && ip.match(/^\d+\.\d+\.\d+\.\d+$/)) {
+          WLED_REMOTE_IP = ip;
+          localStorage.setItem("wled_remote_ip", ip);
+          return ip;
+        } else {
+          alert("Invalid IP address. Please reload and try again.");
+          return null;
+        }
+      }
+      function wledFetch(path, opts) {
+        // Only use protocol and IP if running as file:// (local file)
+        if (location.protocol === "file:") {
+          if (!WLED_REMOTE_IP) return Promise.reject("No WLED IP set");
+          let proto = location.protocol === "https:" ? "https://" : "http://";
+          let url = path;
+          if (typeof path === "string" && path.startsWith("/")) {
+            url = `${proto}${WLED_REMOTE_IP}${path}`;
+          }
+          return fetch(url, opts);
+        } else {
+          // On server, just use the path (relative fetch)
+          return fetch(path, opts);
+        }
+      }
+      function wledWsUrl() {
+        // Always use full protocol + host for WebSocket URL
+        let proto = location.protocol === "https:" ? "wss://" : "ws://";
+        if (location.protocol === "file:") {
+          return `${proto}${WLED_REMOTE_IP}/ws`;
+        } else {
+          return `${proto}${location.host}/ws`;
+        }
+      }
+      // --- Centralized /json/state POST helper ---
+      async function wledPostState(body) {
+        let tries = 0;
+        let ok = false;
+        let resp;
+        while (!ok && tries < 3) {
+          try {
+            resp = await fetch("/json/state", {
+              method: "POST",
+              headers: { "Content-Type": "application/json" },
+              body: JSON.stringify(body),
+            });
+            if (resp.ok) ok = true;
+          } catch (e) {}
+          if (!ok) await new Promise((r) => setTimeout(r, 150));
+          tries++;
+        }
+        return resp;
+      }
 
