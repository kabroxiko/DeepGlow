+// Helper to enforce minimum transition time and max brightness
+void enforceAquariumSafety() {
+  extern uint16_t aquariumMinTransitionTime;
+  extern uint8_t aquariumMaxBrightness;
+  uint16_t minTransition = aquariumMinTransitionTime;
+  if (minTransition > 0) {
+    if (minTransition == 1) minTransition = 100;
+    if (strip.getTransition() < minTransition * 100) {
+      strip.setTransition(minTransition * 100);
+    }
+  }
+  if (bri > aquariumMaxBrightness) {
+    bri = aquariumMaxBrightness;
+  }
+}
+
 // deserializes WLED state
