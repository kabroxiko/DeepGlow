+void applyTimebasedPreset() {
+  if (!ntpEnabled) return; // only run if NTP is enabled
+
+  updateLocalTime(); // make sure we have correct local time
+
+  int16_t lastTimer = -1;
+  long smallestTimeDiff = -1; // in minutes
+
+  byte currentWeekday = weekdayMondayFirst(); // 1-7
+  int16_t currentHour = hour(localTime);
+  int16_t currentMinute = minute(localTime);
+  long currentTimeInMinutes = (currentWeekday - 1) * 1440 + currentHour * 60 + currentMinute;
+
+  for (unsigned i = 0; i < 10; i++) { // 8 timers + sunrise/sunset
+    if (timerMacro[i] == 0 || !(timerWeekday[i] & 0x01)) continue;
+
+    int16_t timerHour, timerMinute;
+
+    if (i < 8) { // Regular timers
+      if (timerHours[i] == 24) continue; // "every hour" timers are not candidates for the "last" preset
+      if (!isTodayInDateRange(((timerMonth[i] >> 4) & 0x0F), timerDay[i], timerMonth[i] & 0x0F, timerDayEnd[i])) continue;
+      timerHour = timerHours[i];
+      timerMinute = timerMinutes[i];
+    } else { // Sunrise/Sunset
+      time_t suntime = (i == 8) ? sunrise : sunset;
+      if (!suntime) continue;
+      time_t tmp = suntime + timerMinutes[i] * 60;
+      timerHour = hour(tmp);
+      timerMinute = minute(tmp);
+    }
+
+    for (int d = 1; d <= 7; d++) { // check all 7 days of the week
+      if (!((timerWeekday[i] >> d) & 0x01)) continue; // if timer is not enabled for this day, skip
+
+      long timerTimeInMinutes = (d - 1) * 1440 + timerHour * 60 + timerMinute;
+      long timeDiff = currentTimeInMinutes - timerTimeInMinutes;
+
+      if (timeDiff < 0) { // timer is in the future this week
+        timeDiff += 7 * 1440; // look at last week
+      }
+
+      if (smallestTimeDiff == -1 || timeDiff < smallestTimeDiff) {
+        smallestTimeDiff = timeDiff;
+        lastTimer = i;
+      }
+    }
+  }
+
+  if (lastTimer != -1) {
+    applyPreset(timerMacro[lastTimer]);
+  }
+}
